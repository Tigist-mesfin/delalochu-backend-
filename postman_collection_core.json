{
  "info": {
    "name": "delalochu Module APIs",
    "_postman_id": "",
    "description": "Postman collection for core module endpoints (users, staff, clients, brokers, roles, permissions, reviews)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "jwtToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/users/register" }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/users/login" }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/users" }
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/users/:id" }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated Name\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/users/:id" }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/users/:id" }
          }
        }
      ]
    },
    {
      "name": "Staff",
      "item": [
        {
          "name": "Create Staff",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Staff Name\",\n  \"email\": \"staff@example.com\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/staff" }
          }
        },
        { "name": "Get All Staff", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/staff" } } },
        { "name": "Get Staff By ID", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/staff/:id" } } },
        { "name": "Update Staff", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "body": { "mode": "raw", "raw": "{\n  \"email\": \"newstaff@example.com\"\n}" }, "url": { "raw": "{{baseUrl}}/api/staff/:id" } } },
        { "name": "Delete Staff", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/staff/:id" } } }
      ]
    },
    {
      "name": "Staff Roles",
      "item": [
        { "name": "Create Role", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Manager\"\n}" }, "url": { "raw": "{{baseUrl}}/api/staff-roles" } } },
        { "name": "Get All Roles", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/staff-roles" } } },
        { "name": "Get Role By ID", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/staff-roles/:id" } } },
        { "name": "Update Role", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated Role\"\n}" }, "url": { "raw": "{{baseUrl}}/api/staff-roles/:id" } } },
        { "name": "Delete Role", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/staff-roles/:id" } } }
      ]
    },
    {
      "name": "Staff Permissions",
      "item": [
        { "name": "Create Permission", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "body": { "mode": "raw", "raw": "{\n  \"name\": \"manage_users\"\n}" }, "url": { "raw": "{{baseUrl}}/api/staff-permissions" } } },
        { "name": "Get All Permissions", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/staff-permissions" } } },
        { "name": "Get Permission By ID", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/staff-permissions/:id" } } },
        { "name": "Update Permission", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "body": { "mode": "raw", "raw": "{\n  \"name\": \"updated_permission\"\n}" }, "url": { "raw": "{{baseUrl}}/api/staff-permissions/:id" } } },
        { "name": "Delete Permission", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/staff-permissions/:id" } } }
      ]
    },
    {
      "name": "Clients",
      "item": [
        { "name": "Create Client", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Client Name\",\n  \"email\": \"client@example.com\"\n}" }, "url": { "raw": "{{baseUrl}}/api/clients" } } },
        { "name": "Get All Clients", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/clients" } } },
        { "name": "Get Client By ID", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/clients/:id" } } },
        { "name": "Update Client", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated Client\"\n}" }, "url": { "raw": "{{baseUrl}}/api/clients/:id" } } },
        { "name": "Delete Client", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/clients/:id" } } }
      ]
    },
    {
      "name": "Brokers",
      "item": [
        { "name": "Create Broker", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Broker Name\",\n  \"email\": \"broker@example.com\"\n}" }, "url": { "raw": "{{baseUrl}}/api/brokers" } } },
        { "name": "Get All Brokers", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/brokers" } } },
        { "name": "Get Broker By ID", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/brokers/:id" } } },
        { "name": "Update Broker", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated Broker\"\n}" }, "url": { "raw": "{{baseUrl}}/api/brokers/:id" } } },
        { "name": "Delete Broker", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/brokers/:id" } } }
      ]
    },
    {
      "name": "Broker Reviews",
      "item": [
        { "name": "Create Review", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "body": { "mode": "raw", "raw": "{\n  \"brokerId\": \"<broker-id>\",\n  \"rating\": 5,\n  \"comment\": \"Great service\"\n}" }, "url": { "raw": "{{baseUrl}}/api/broker-reviews" } } },
        { "name": "Get All Reviews", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/broker-reviews" } } },
        { "name": "Get Review By ID", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/broker-reviews/:id" } } },
        { "name": "Update Review", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "body": { "mode": "raw", "raw": "{\n  \"rating\": 4\n}" }, "url": { "raw": "{{baseUrl}}/api/broker-reviews/:id" } } },
        { "name": "Delete Review", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/broker-reviews/:id" } } }
      ]
    }
  ]
}
