        { "name": "Update Role", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "body": { "mode": "raw", "raw": "{\n  \"rolename\": \"Updated Role\"\n}" }, "url": { "raw": "{{baseUrl}}/api/staff-roles/:id" } } },
        { "name": "Delete Role", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/staff-roles/:id" } } }
      ]
    },
    {
      "name": "Staff Permissions",
      "item": [
        { "name": "Create Permission", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "body": { "mode": "raw", "raw": "{\n  \"staff_role_id\": 2,\n  \"module\": \"USERS\",\n  \"can_create\": true,\n  \"can_read\": true,\n  \"can_update\": false,\n  \"can_delete\": false,\n  \"granted_by_staff_id\": 5,\n  \"granted_at\": \"2026-06-15T00:00:00.000Z\",\n  \"note\": \"Initial grant\"\n}" }, "url": { "raw": "{{baseUrl}}/api/staff-permissions" } } },
        { "name": "Get All Permissions", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/staff-permissions" } } },
        { "name": "Get Permission By ID", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/staff-permissions/:id" } } },
        { "name": "Update Permission", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "body": { "mode": "raw", "raw": "{\n  \"can_create\": false,\n  \"can_update\": true\n}" }, "url": { "raw": "{{baseUrl}}/api/staff-permissions/:id" } } },
        { "name": "Delete Permission", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/staff-permissions/:id" } } }
      ]
    },
    {
      "name": "Clients",
      "item": [
        { "name": "Create Client", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "body": { "mode": "raw", "raw": "{\n  \"user_id\": 200,\n  \"registered_by_staff_id\": null,\n  \"referred_by_broker_id\": null,\n  \"registration_type\": \"APP\",\n  \"client_category\": \"BUYER\",\n  \"requested_service\": \"PROPERTY_SEARCH\"\n}" }, "url": { "raw": "{{baseUrl}}/api/clients" } } },
        { "name": "Get All Clients", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/clients" } } },
        { "name": "Get Client By ID", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/clients/:id" } } },
        { "name": "Update Client", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "body": { "mode": "raw", "raw": "{\n  \"client_category\": \"SELLER\"\n}" }, "url": { "raw": "{{baseUrl}}/api/clients/:id" } } },
        { "name": "Delete Client", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/clients/:id" } } }
      ]
    },
    {
      "name": "Brokers",
      "item": [
        { "name": "Create Broker", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "body": { "mode": "raw", "raw": "{\n  \"user_id\": 300,\n  \"verification_status\": \"PENDING\",\n  \"experience\": 5,\n  \"region\": \"Addis Ababa\",\n  \"city\": \"Addis Ababa\",\n  \"woreda\": \"01\",\n  \"specific_area\": \"Bole\",\n  \"doc\": \"\",\n  \"total_deals_closed\": 0,\n  \"rating\": 0,\n  \"broker_status\": \"ACTIVE\",\n  \"wallet_balance\": 0\n}" }, "url": { "raw": "{{baseUrl}}/api/brokers" } } },
        { "name": "Get All Brokers", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/brokers" } } },
        { "name": "Get Broker By ID", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/brokers/:id" } } },
        { "name": "Update Broker", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "body": { "mode": "raw", "raw": "{\n  \"rating\": 4\n}" }, "url": { "raw": "{{baseUrl}}/api/brokers/:id" } } },
        { "name": "Delete Broker", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/brokers/:id" } } }
      ]
    },
    {
      "name": "Broker Reviews",
      "item": [
        { "name": "Create Review", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "body": { "mode": "raw", "raw": "{\n  \"broker_id\": 300,\n  \"commentor_user_id\": 200,\n  \"interaction_type\": \"LIKE\",\n  \"comment\": \"Great service\",\n  \"date\": \"2026-06-15T00:00:00.000Z\"\n}" }, "url": { "raw": "{{baseUrl}}/api/broker-reviews" } } },
        { "name": "Get All Reviews", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/broker-reviews" } } },
        { "name": "Get Review By ID", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/broker-reviews/:id" } } },
        { "name": "Update Review", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "body": { "mode": "raw", "raw": "{\n  \"interaction_type\": \"DISLIKE\"\n}" }, "url": { "raw": "{{baseUrl}}/api/broker-reviews/:id" } } },
        { "name": "Delete Review", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{jwtToken}}" } ], "url": { "raw": "{{baseUrl}}/api/broker-reviews/:id" } } }
      ]
